# ==========================================
# 开发环境配置 (Development)
# ==========================================
# 复制此文件为 .env 用于本地开发
# cp .env.example .env

# App
APP_NAME=cnalias
APP_ENV=development
LOG_LEVEL=debug

# Database (使用外部 Docker 容器，本地连接)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=cnalias
DB_SSLMODE=disable

# Redis (使用外部 Docker 容器，本地连接)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT (开发环境)
JWT_SECRET=dev-secret-key-change-in-production

# Server (开发环境端口)
SERVER_PORT=8081
