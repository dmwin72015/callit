# ==========================================
# 开发环境配置 (Development)
# ==========================================
# 复制此文件为 .env 用于开发
# cp .env.example .env

# App
APP_NAME=cnalias
APP_ENV=development
LOG_LEVEL=debug

# Database (使用外部 Docker 容器)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=cnalias
DB_SSLMODE=disable

# Redis (使用外部 Docker 容器)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=dev-secret-key-change-in-production

# Server
SERVER_PORT=8081

# ==========================================
# 生产环境配置 (Production)
# ==========================================
# 生产环境使用 docker-compose.yml 启动
# 这些配置在 docker-compose.yml 中通过环境变量注入
#
# 如果需要在生产环境直接运行（不使用 Docker）：
# cp .env.example .env.production
# 然后取消下面的注释并修改配置：
#
# # Database
# DB_HOST=your-postgres-host
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your-secure-password
# DB_NAME=cnalias
# DB_SSLMODE=disable
#
# # Redis
# REDIS_HOST=your-redis-host
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password
# REDIS_DB=0
#
# # JWT (生产环境必须修改！)
# JWT_SECRET=your-super-secret-jwt-key-here
# JWT_ACCESS_TOKEN_TTL=15m
# JWT_REFRESH_TOKEN_TTL=168h
#
# # Server
# SERVER_PORT=8080
# APP_ENV=production
