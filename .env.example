# App
APP_NAME=cnalias
APP_ENV=development
LOG_LEVEL=debug

# Database (开发环境使用 Docker)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=cnalias
DB_SSLMODE=disable

# Redis (开发环境使用 Docker)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=dev-secret-key-change-in-production

# Server
SERVER_PORT=8081

# Optional: 生产环境覆盖
# DB_HOST=postgres
# REDIS_HOST=redis
